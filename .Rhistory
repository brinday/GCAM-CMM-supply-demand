# we need to interpolate to find what cost the cumulative prod value is at for each group
res_supply_curve_origin_interpolate <- Fig1b_res_supply_curve_origin %>%
full_join(Fig1b_res_cum_prod, by = c("scenario", "region", "resource", "subresource", "year", "Units.Q" = "Units", "value.Q" = "value")) %>%
group_by(Units.Q, scenario, region, resource, subresource, year) %>%
arrange(value.Q, .by_group = TRUE) %>%
# if value.cost is NA, fill by linearly interpolating based on value.Q
mutate(
value.cost = {
n_non_na <- sum(!is.na(value.cost))
n_na     <- sum(is.na(value.cost))
if (n_na == 0 || n_non_na < 2) {
value.cost
} else {
approx(
x = value.Q[!is.na(value.cost)],
y = value.cost[!is.na(value.cost)],
xout = value.Q,
rule = 2
)$y
}
}
) %>%
ungroup() %>%
left_join(Fig1b_res_cum_prod, by = c("scenario", "region", "resource", "subresource", "year", "Units.Q" = "Units")) %>%
rename(value.prod = value) %>%
mutate(vintage = subresource) %>%
separate(vintage, into = c(NA, "vintage"), sep = "_") %>%
mutate(vintage = as.numeric(vintage))
